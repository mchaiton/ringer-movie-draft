backend/data/*.db-journal
backend/data/oscar_nominations.json

# ─── Frontend: build output ───────────────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor files ────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Misc ────────────────────────────────────────────────────────────────────
*.tgz
.cache/
